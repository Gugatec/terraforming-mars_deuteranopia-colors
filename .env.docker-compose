# Copy this file, fill in your values, and pass it when running compose:
#   docker compose --env-file .env.docker-compose up -d
# Never commit a file containing real credentials.

# Host port mapped to the app (container always listens on 8080)
HOST_PORT=8080

# PostgreSQL credentials
POSTGRES_USER=tmars
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tmars

# Unique server identifier.
# Used to access the admin interface at:
# http://localhost:8080/game?id=<SERVER_ID>
SERVER_ID=my-tmars-server
